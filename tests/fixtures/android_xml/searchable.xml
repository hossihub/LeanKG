<?xml version="1.0" encoding="utf-8"?>
<searchable 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:label="@string/app_name"
    android:hint="@string/search_hint"
    android:searchMode="queryRewriteFromText"
    android:searchSuggestAuthority="com.tv.app.provider"
    android:searchSuggestPath="channels"
    android:searchSuggestSelection=" ?"
    android:searchSuggestIntentAction="android.intent.action.VIEW"
    android:searchSuggestIntentData="content://com.tv.app.provider/channels"
    android:voiceSearchMode="showVoiceSearchButton|launchWebSearch"
    android:voiceLanguageModel="free_form"
    android:includeInGlobalSearch="true"
    android:queryAfterZeroResults="true">

    <actionkey
        android:keycode="KEYCODE_MEDIA_PLAY"
        android:action="play_channel" />

</searchable>
